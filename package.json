{
  "name": "opentalk-outlook-add-in",
  "version": "0.2.5",
  "description": "OpenTalk Outlook Add-in",
  "repository": {
    "type": "git",
    "url": "https://gitlab.opencode.de/opentalk/opentalk-outlook-add-in.git"
  },
  "license": "EUPL-1.2",
  "config": {
    "app_to_debug": "outlook",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3001
  },
  "scripts": {
    "lint": "pnpm eslint",
    "fmt": "pnpm prettier --write \"**/*.{mjs,js,jsx,ts,tsx}\"",
    "fmt:ci": "pnpm prettier --check \"**/*.{mjs,js,jsx,ts,tsx}\"",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch",
    "deps:circular": "madge --circular .",
    "deps:unused": "knip --include dependencies,files"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^5.17.1",
    "@types/lodash": "^4.17.17",
    "core-js": "^3.41.0",
    "i18next-http-backend": "^3.0.2",
    "lodash": "^4.17.21",
    "react": "^17.0.2",
    "react-app-polyfill": "^3.0.0",
    "react-dom": "^17.0.2",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.27.3",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime-corejs3": "^7.27.3",
    "@types/office-js": "^1.0.502",
    "@types/office-runtime": "^1.0.35",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "@types/webpack": "^5.28.5",
    "@types/webpack-env": "^1.18.8",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^9.27.0",
    "eslint-plugin-react": "^7.37.5",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "i18next": "^25.5.2",
    "knip": "^5.58.0",
    "madge": "^8.0.0",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "prettier": "^3.5.3",
    "react-i18next": "^15.7.3",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.2.1",
    "whatwg-fetch": "^3.6.20"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ],
  "packageManager": "pnpm@10.2.0+sha512.0d27364e0139c6aadeed65ada153135e0ca96c8da42123bd50047f961339dc7a758fc2e944b428f52be570d1bd3372455c1c65fa2e7aa0bfbf931190f9552001"
}
